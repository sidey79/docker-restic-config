RESTIC_REPOSITORY=sftp:tiffy:/data/zeus/restic/bitwarden
RESTIC_TAG=bitwarden
BACKUP_PATHS="/source/1"
RESTIC_CONTAINER_BACKUP_SOURCE_1=/var/lib/docker/volumes/vaultwarden_bwdata/_data
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=12

PRE_BACKUP_COMMAND='echo "==> Stopping Vaultwarden container: bitwarden"; docker stop bitwarden'
POST_BACKUP_COMMAND='echo "==> Starting Vaultwarden container: bitwarden"; docker start bitwarden'

SYSTEMD_ON_CALENDAR="*-*-* 00,06,12,18:35:00"
SYSTEMD_RANDOMIZED_DELAY_SEC=5m
SYSTEMD_ACCURACY_SEC=1m
