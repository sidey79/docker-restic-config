RESTIC_REPOSITORY=sftp:tiffy:/data/zeus/restic/paperless
RESTIC_TAG=paperless
BACKUP_PATHS="/source/paperless-ngx/db/latest.sql /source/paperless-data /source/paperless-media"
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=12

SYSTEMD_ON_CALENDAR="*-*-* 03:05:00"
SYSTEMD_RANDOMIZED_DELAY_SEC=5m
SYSTEMD_ACCURACY_SEC=1m

PRE_BACKUP_COMMAND='dump_dir="${PAPERLESS_DB_DUMP_DIR:-/opt/docker/paperless-ngx/db}"; out="${dump_dir}/latest.sql"; tmp="$(mktemp "${dump_dir}/latest.sql.tmp.XXXXXX")"; docker exec paperless-ngx-db-1 pg_dump --clean --if-exists --no-owner --no-privileges -U paperless-db-user -d paperless > "${tmp}"; chmod 0644 "${tmp}"; mv "${tmp}" "${out}"'
