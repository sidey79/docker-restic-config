RESTIC_REPOSITORY=sftp:tiffy:/data/zeus/restic/paperless
RESTIC_TAG=paperless
BACKUP_PATHS="/source/paperless-ngx/db/latest.sql /source/paperless-data /source/paperless-media"
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=12

SYSTEMD_ON_CALENDAR="*-*-* 03:05:00"
SYSTEMD_RANDOMIZED_DELAY_SEC=5m
SYSTEMD_ACCURACY_SEC=1m

PAPERLESS_STOP_CONTAINERS="paperless-ngx-webserver-1"
PAPERLESS_DB_CONTAINER=paperless-ngx-db-1
PAPERLESS_DB_NAME=paperless
PAPERLESS_DB_USER=paperless-db-user
PAPERLESS_DB_DUMP_DIR=/srv/backup/zeus/paperless-ngx/db

PRE_BACKUP_COMMAND='echo "==> Stopping Paperless container(s): ${PAPERLESS_STOP_CONTAINERS}"; docker stop ${PAPERLESS_STOP_CONTAINERS}; dump_dir="${PAPERLESS_DB_DUMP_DIR}"; out="${dump_dir}/latest.sql"; tmp="$(mktemp "${dump_dir}/latest.sql.tmp.XXXXXX")"; echo "==> Creating Paperless PostgreSQL dump from ${PAPERLESS_DB_CONTAINER}/${PAPERLESS_DB_NAME}: ${out}"; docker exec "${PAPERLESS_DB_CONTAINER}" pg_dump --clean --if-exists --no-owner --no-privileges -U "${PAPERLESS_DB_USER}" -d "${PAPERLESS_DB_NAME}" > "${tmp}"; chmod 0644 "${tmp}"; mv "${tmp}" "${out}"; echo "==> Paperless PostgreSQL dump ready: ${out}"'
POST_BACKUP_COMMAND='echo "==> Starting Paperless container(s): ${PAPERLESS_STOP_CONTAINERS}"; docker start ${PAPERLESS_STOP_CONTAINERS}; echo "==> Paperless container(s) started: ${PAPERLESS_STOP_CONTAINERS}"'
