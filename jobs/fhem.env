RESTIC_REPOSITORY=sftp:tiffy:/data/zeus/restic/fhem
RESTIC_TAG=fhem
BACKUP_PATHS="/source/1 /source/2/fhem/latest.sql"
RESTIC_CONTAINER_BACKUP_SOURCE_1=/opt/docker/fhem/app
RESTIC_CONTAINER_BACKUP_SOURCE_2=/srv/backup/zeus
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=12

SYSTEMD_ON_CALENDAR="*-*-* 00:16:00"
SYSTEMD_RANDOMIZED_DELAY_SEC=1m
SYSTEMD_ACCURACY_SEC=1m

FHEM_WEB_URL=https://zeus:8088/fhem
FHEM_WEB_INSECURE=1
FHEM_BACKUP_WAIT_TIMEOUT=10800
FHEM_BACKUP_WAIT_INTERVAL=30

FHEM_DB_CONTAINER=mariadb
FHEM_DB_NAME=fhem
FHEM_DB_USER=root
FHEM_DB_DUMP_FILE=/backup/latest.sql

PRE_BACKUP_COMMAND='./scripts/restic-fhem-pre-backup.sh'
