# Restic credentials.
# Override RESTIC_PASSWORD in Portainer or another secret source for production.
RESTIC_PASSWORD=change-this-password

# Restic runtime paths.
RESTIC_REPOSITORY_DIR=/opt/docker/restic/repository
RESTIC_SSH_DIR=/opt/docker/duplicati/config/.ssh
RESTIC_CACHE_DIR=/opt/docker/restic/cache
RESTIC_RESTORE_DIR=/opt/docker/restic/restore
RESTIC_OUTPUT_DIR=/opt/docker/restic/output
N8N_BACKUP_WEBHOOK_URL=https://127.0.0.1:5678/webhook/backup-wf/backup-status
N8N_BACKUP_WEBHOOK_TIMEOUT=10
N8N_BACKUP_WEBHOOK_INSECURE=1

# Optional Portainer backup settings. Put PORTAINER_API_KEY and
# PORTAINER_BACKUP_PASSWORD into /etc/docker-restic-config/secrets.env for
# systemd-driven backups.
PORTAINER_URL=https://127.0.0.1:9443
PORTAINER_BACKUP_INSECURE=1

# Default retention policy. Job files can override these values.
RESTIC_KEEP_DAILY=14
RESTIC_KEEP_WEEKLY=8
RESTIC_KEEP_MONTHLY=12
