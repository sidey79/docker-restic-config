# Restic credentials.
# Override RESTIC_PASSWORD in Portainer or another secret source for production.
RESTIC_PASSWORD=change-this-password

# Restic runtime paths.
RESTIC_REPOSITORY_DIR=/opt/docker/restic/repository
RESTIC_SSH_DIR=/opt/docker/duplicati/config/.ssh
RESTIC_CACHE_DIR=/opt/docker/restic/cache
RESTIC_RESTORE_DIR=/opt/docker/restic/restore
RESTIC_OUTPUT_DIR=/opt/docker/restic/output
N8N_BACKUP_WEBHOOK_URL=https://127.0.0.1:5678/webhook/backup-wf/backup-status
N8N_BACKUP_WEBHOOK_TIMEOUT=10
N8N_BACKUP_WEBHOOK_INSECURE=1

# Default retention policy. Job files can override these values.
RESTIC_KEEP_DAILY=14
RESTIC_KEEP_WEEKLY=8
RESTIC_KEEP_MONTHLY=12

# Paths for backup sources.
BACKUP_SOURCE_ZEUS=/srv/backup/zeus
BACKUP_SOURCE_ECODMS=/srv/backup/zeus/ecodms
BACKUP_SOURCE_PAPERLESS=/srv/backup/zeus/paperless-ngx
BACKUP_SOURCE_PAPERLESS_DATA=/opt/docker/paperless-ngx/data
BACKUP_SOURCE_PAPERLESS_MEDIA=/opt/docker/paperless-ngx/media
BACKUP_SOURCE_ETC=/etc
BACKUP_SOURCE_FHEM=/opt/docker/fhem/app
BACKUP_SOURCE_WORDPRESS=/opt/docker/wordpress/backup
BACKUP_SOURCE_PICTURES=/srv/media/pictures
BACKUP_SOURCE_BITWARDEN=/opt/docker/bitwarden/backup
BACKUP_SOURCE_Z2M=/opt/docker/fhem/zigbee2mqtt/data
BACKUP_SOURCE_N8N=/srv/backup/zeus/n8n
BACKUP_SOURCE_PORTAINER=/srv/backup/zeus/portainer
