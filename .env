# Optional default repository targets for service-specific scripts.
# Examples:
# RESTIC_PAPERLESS_REPOSITORY=sftp:tiffy:/data/zeus/restic/paperless
RESTIC_PAPERLESS_REPOSITORY=sftp:tiffy:/data/zeus/restic/paperless
RESTIC_REPOSITORY_DIR=/opt/docker/restic/repository
# Set external to avoid pushing the password to the repository.
# RESTIC_PASSWORD=change-this-password
RESTIC_SSH_DIR=/opt/docker/duplicati/config/.ssh
RESTIC_CACHE_DIR=/opt/docker/restic/cache
RESTIC_RESTORE_DIR=/opt/docker/restic/restore
N8N_BACKUP_WEBHOOK_URL=https://n8n:5678/webhook/backup-wf/backup-status

# Retention policy.
RESTIC_KEEP_DAILY=14
RESTIC_KEEP_WEEKLY=8
RESTIC_KEEP_MONTHLY=12
